{
  "uid": "fleet-overview",
  "title": "Fleet Overview — Control Room",
  "description": "Operator view: all turbines at a glance. This is what a real SCADA HMI main screen looks like.",
  "tags": ["scada", "fleet", "operator"],
  "timezone": "browser",
  "refresh": "5s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Total Farm Power Output (kW)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "InfluxDB-SCADA" },
      "targets": [
        {
          "query": "from(bucket: \"scada\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"telemetry\")\n  |> filter(fn: (r) => r.sensor == \"PowerOutput\")\n  |> group(columns: [\"turbine_id\"])\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "kwatt",
          "custom": { "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 2,
      "title": "Wind Speed (m/s)",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 8 },
      "datasource": { "type": "influxdb", "uid": "InfluxDB-SCADA" },
      "targets": [
        {
          "query": "from(bucket: \"scada\")\n  |> range(start: -1m)\n  |> filter(fn: (r) => r._measurement == \"telemetry\")\n  |> filter(fn: (r) => r.sensor == \"WindSpeed\")\n  |> group()\n  |> mean()",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "velocityms",
          "min": 0,
          "max": 30,
          "thresholds": {
            "steps": [
              { "value": 0, "color": "red" },
              { "value": 3.5, "color": "green" },
              { "value": 25, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Turbine Power Output per Turbine",
      "type": "bargauge",
      "gridPos": { "h": 6, "w": 18, "x": 6, "y": 8 },
      "datasource": { "type": "influxdb", "uid": "InfluxDB-SCADA" },
      "targets": [
        {
          "query": "from(bucket: \"scada\")\n  |> range(start: -1m)\n  |> filter(fn: (r) => r._measurement == \"telemetry\")\n  |> filter(fn: (r) => r.sensor == \"PowerOutput\")\n  |> group(columns: [\"turbine_id\"])\n  |> last()",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "kwatt",
          "min": 0,
          "max": 3000,
          "thresholds": {
            "steps": [
              { "value": 0, "color": "red" },
              { "value": 500, "color": "yellow" },
              { "value": 1000, "color": "green" }
            ]
          }
        }
      },
      "options": { "orientation": "horizontal", "displayMode": "gradient" }
    },
    {
      "id": 4,
      "title": "Nacelle Temperature per Turbine (°C)",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "influxdb", "uid": "InfluxDB-SCADA" },
      "targets": [
        {
          "query": "from(bucket: \"scada\")\n  |> range(start: -1m)\n  |> filter(fn: (r) => r._measurement == \"telemetry\")\n  |> filter(fn: (r) => r.sensor == \"NacelleTemp\")\n  |> group(columns: [\"turbine_id\"])\n  |> last()\n  |> keep(columns: [\"turbine_id\", \"_value\"])",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 70, "color": "yellow" },
              { "value": 80, "color": "red" }
            ]
          },
          "custom": { "displayMode": "color-background" }
        }
      }
    },
    {
      "id": 5,
      "title": "Active Alerts",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "influxdb", "uid": "InfluxDB-SCADA" },
      "targets": [
        {
          "query": "from(bucket: \"scada\")\n  |> range(start: -1h)\n  |> filter(fn: (r) => r._measurement == \"alerts\")\n  |> sort(columns: [\"_time\"], desc: true)\n  |> limit(n: 20)\n  |> keep(columns: [\"_time\", \"turbine_id\", \"alert_type\", \"severity\", \"_value\"])",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39
}
